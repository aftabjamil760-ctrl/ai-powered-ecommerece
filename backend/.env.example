# Copy to .env and fill in your values. Never commit real .env to git.

PORT=5000
MONGODB_URI=your_mongodb_atlas_uri
JWT_SECRET=your_jwt_secret

# Groq Cloud (chat) — key from https://console.groq.com/keys (starts with gsk_)
GROQ_API_KEY=your_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# Optional: HuggingFace token for better RAG embeddings (https://huggingface.co/settings/tokens)
HF_API_KEY=
CHATBOT_FALLBACK_MODE=true

# Optional: payment FAQ contact info shown by chatbot
SUPPORT_EMAIL=support@ecommerence-store.com
SUPPORT_PHONE=+92-300-0000000

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=embedding-001
GEMINI_CHAT_MODEL=gemini-1.5-flash
